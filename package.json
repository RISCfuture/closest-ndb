{
  "name": "closest-ndb",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "ci:build": "vue-tsc --noEmit && vite build",
    "ci:unit": "vitest --run",
    "dev": "vite",
    "doc": "npx typedoc --out docs src",
    "format": "prettier --write .",
    "lint": "yarn lint:eslint && yarn lint:oxlint && yarn lint:stylelint && yarn lint:knip",
    "lint:eslint": "eslint .",
    "lint:oxlint": "oxlint -c oxlintrc.json src",
    "lint:knip": "knip",
    "lint:stylelint": "stylelint \"src/**/*.{vue,css,scss,sass}\"",
    "preview": "vite preview",
    "test:e2e": "yarn build && playwright test",
    "test:e2e:dev": "playwright test --ui",
    "test:unit": "vitest",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@intlify/core-base": "^11.3.0",
    "@sentry/vue": "^10.45.0",
    "lodash-es": "^4.17.23",
    "motion": "^12.38.0",
    "normalize.css": "^8.0.1",
    "pinia": "^3.0.4",
    "playwright": "^1.59.1",
    "ua-parser-js": "^2.0.9",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@flydotio/dockerfile": "^0.7.10",
    "@opentelemetry/api": "^1.9.0",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.59.1",
    "@types/jsdom": "^28.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@types/setimmediate": "^1.0.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser": "^4.1.1",
    "@vitest/browser-playwright": "^4.1.1",
    "@vue/compiler-core": "^3.5.30",
    "@vue/compiler-dom": "^3.5.30",
    "@vue/server-renderer": "^3.5.30",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "knip": "^6.0.5",
    "oxlint": "^1.57.0",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "setimmediate": "^1.0.5",
    "stylelint": "^17.5.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.2",
    "vite-plugin-csp-guard": "^3.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.1",
    "vitest-browser-vue": "^2.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "yarn@4.13.0",
  "dependenciesMeta": {
    "vite-plugin-csp-guard@3.0.0": {
      "unplugged": true
    }
  }
}
